# Model
MODEL_NAME=gpt2
HF_HOME=/models

# Input limits
MAX_INPUT_CHARS=10000
MAX_TOKEN_IDS=4096
MAX_NEW_TOKENS_LIMIT=512

# Database (leave empty/unset to disable history)
DATABASE_URL=postgresql+asyncpg://llm:llm@db:5432/llm
ENABLE_HISTORY=true

# API
LOG_LEVEL=INFO
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
